from functools import cmp_to_key

class Solution(object):
    def largestNumber(self, nums):
        def compare(a, b):
            if a + b > b + a:
                return -1
            elif a + b < b + a:
                return 1
            return 0

        nums = list(map(str, nums))
        nums.sort(key=cmp_to_key(compare))

        result = ''.join(nums)

        # Handle cases like [0,0]
        return "0" if result[0] == '0' else result
