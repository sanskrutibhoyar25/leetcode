class Solution(object):
    def convert(self, s, numRows):
        """
        :type s: str
        :type numRows: int
        :rtype: str
        """
        
        # Edge case
        if numRows == 1 or numRows >= len(s):
            return s
        
        # Create rows
        rows = [""] * numRows
        
        current_row = 0
        direction = -1
        
        # Traverse characters
        for char in s:
            rows[current_row] += char
            
            # Change direction at top or bottom
            if current_row == 0 or current_row == numRows - 1:
                direction *= -1
            
            current_row += direction
        
        # Join all rows
        return "".join(rows)
